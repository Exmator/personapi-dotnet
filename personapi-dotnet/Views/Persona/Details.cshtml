@model personapi_dotnet.Models.Entities.Persona
@{ ViewData["Title"] = "Detalle Persona"; }

<h2>Detalle Persona</h2>
<dl class="row">
    <dt class="col-sm-2">CC</dt>
    <dd class="col-sm-10">@Model.Cc</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>
    <dt class="col-sm-2">Apellido</dt>
    <dd class="col-sm-10">@Model.Apellido</dd>
    <dt class="col-sm-2">Género</dt>
    <dd class="col-sm-10">@Model.Genero</dd>
    <dt class="col-sm-2">Edad</dt>
    <dd class="col-sm-10">@Model.Edad</dd>
</dl>
<a asp-action="Edit" asp-route-cc="@Model.Cc" class="btn btn-secondary">Editar</a>
<a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
