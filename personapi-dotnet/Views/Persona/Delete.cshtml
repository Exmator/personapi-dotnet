@model personapi_dotnet.Models.Entities.Persona
@{ ViewData["Title"] = "Eliminar Persona"; }

<h2>Eliminar Persona</h2>
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<p class="text-danger">¿Está seguro que desea eliminar este registro?</p>
<dl class="row">
    <dt class="col-sm-2">CC</dt>
    <dd class="col-sm-10">@Model.Cc</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>
    <dt class="col-sm-2">Apellido</dt>
    <dd class="col-sm-10">@Model.Apellido</dd>
    <dt class="col-sm-2">Género</dt>
    <dd class="col-sm-10">@Model.Genero</dd>
    <dt class="col-sm-2">Edad</dt>
    <dd class="col-sm-10">@Model.Edad</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Cc" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
