@model personapi_dotnet.Models.Entities.Telefono
@{ ViewData["Title"] = "Eliminar Teléfono"; }

<h2>Eliminar Teléfono</h2>
<p class="text-danger">¿Está seguro que desea eliminar este registro?</p>
<dl class="row">
    <dt class="col-sm-2">Número</dt>
    <dd class="col-sm-10">@Model.Num</dd>
    <dt class="col-sm-2">Operador</dt>
    <dd class="col-sm-10">@Model.Oper</dd>
    <dt class="col-sm-2">Dueño (CC)</dt>
    <dd class="col-sm-10">@Model.Duenio</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Num" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
