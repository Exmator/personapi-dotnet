@model personapi_dotnet.Models.Entities.Telefono
@{ ViewData["Title"] = "Nuevo Teléfono"; }

<h2>Nuevo Teléfono</h2>
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Num" class="form-label"></label>
        <input asp-for="Num" class="form-control" />
        <span asp-validation-for="Num" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Oper" class="form-label"></label>
        <input asp-for="Oper" class="form-control" />
        <span asp-validation-for="Oper" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Duenio" class="form-label"></label>
        <input asp-for="Duenio" class="form-control" />
        <span asp-validation-for="Duenio" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
