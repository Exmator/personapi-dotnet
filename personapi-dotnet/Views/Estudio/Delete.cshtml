@model personapi_dotnet.Models.Entities.Estudio
@{ ViewData["Title"] = "Eliminar Estudio"; }

<h2>Eliminar Estudio</h2>
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<p class="text-danger">¿Está seguro que desea eliminar este registro?</p>
<dl class="row">
    <dt class="col-sm-2">ID Profesión</dt>
    <dd class="col-sm-10">@Model.IdProf</dd>
    <dt class="col-sm-2">CC Persona</dt>
    <dd class="col-sm-10">@Model.CcPer</dd>
    <dt class="col-sm-2">Fecha</dt>
    <dd class="col-sm-10">@Model.Fecha</dd>
    <dt class="col-sm-2">Universidad</dt>
    <dd class="col-sm-10">@Model.Univer</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="IdProf" />
    <input type="hidden" asp-for="CcPer" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
