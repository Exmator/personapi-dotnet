@model personapi_dotnet.Models.Entities.Estudio
@{ ViewData["Title"] = "Editar Estudio"; }

<h2>Editar Estudio</h2>
<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="IdProf" />
    <input type="hidden" asp-for="CcPer" />
    <div class="mb-3">
        <label asp-for="IdProf" class="form-label"></label>
        <input asp-for="IdProf" class="form-control" readonly />
    </div>
    <div class="mb-3">
        <label asp-for="CcPer" class="form-label"></label>
        <input asp-for="CcPer" class="form-control" readonly />
    </div>
    <div class="mb-3">
        <label asp-for="Fecha" class="form-label"></label>
        <input asp-for="Fecha" class="form-control" type="date" />
        <span asp-validation-for="Fecha" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Univer" class="form-label"></label>
        <input asp-for="Univer" class="form-control" />
        <span asp-validation-for="Univer" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
