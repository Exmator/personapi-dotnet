@model personapi_dotnet.Models.Entities.Estudio
@{ ViewData["Title"] = "Detalle Estudio"; }

<h2>Detalle Estudio</h2>
<dl class="row">
    <dt class="col-sm-2">ID Profesión</dt>
    <dd class="col-sm-10">@Model.IdProf</dd>
    <dt class="col-sm-2">CC Persona</dt>
    <dd class="col-sm-10">@Model.CcPer</dd>
    <dt class="col-sm-2">Fecha</dt>
    <dd class="col-sm-10">@Model.Fecha</dd>
    <dt class="col-sm-2">Universidad</dt>
    <dd class="col-sm-10">@Model.Univer</dd>
</dl>
<a asp-action="Edit" asp-route-idProf="@Model.IdProf" asp-route-ccPer="@Model.CcPer" class="btn btn-secondary">Editar</a>
<a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
